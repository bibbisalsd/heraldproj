# Core runtime defaults
JARVIS_VERSION=0.1.0-alpha.1
JARVIS_DEGRADED_MODE=false
ALLOW_DANGEROUS_TOOLS=false
WAKE_WORD_ENABLED=true
WAKE_WORD_PHRASE=jarvis
STT_MODEL=small.en
TTS_MODEL=Kokoro-82M
JARVIS_TTS_BACKEND=kokoro
AUDIO_INPUT_DEVICE_ID=default
AUDIO_OUTPUT_DEVICE_ID=default
RENDERER_MODEL_PREFERRED=llama3.2:1b
RENDERER_MODEL_FALLBACK=llama3.2:3b
VISION_LITE_MODEL=qwen2.5vl:3b
VISION_BG1_MODEL=qwen3-vl:8b
CODE_BG1_MODEL=deepcoder:14b
EMBEDDING_MODEL=nomic-embed-text-v2-moe
JARVIS_ENABLE_EMBEDDING_MATCH=true
JARVIS_ENABLE_SEMANTIC_MEMORY_RETRIEVAL=true
LOCAL_PROFILE_OVERRIDE=

# Lane and queue defaults
BG1_MAX_ACTIVE_JOBS=1
BG1_MAX_QUEUE_LENGTH=1
BG1_QUEUE_TTL_SECONDS=120

# Retention defaults
TRANSCRIPT_RETENTION_DAYS=14
ARTIFACT_RETENTION_DAYS=7
MEMORY_RETENTION_DAYS=90
RETENTION_PURGE_INTERVAL_HOURS=24
